LLM_BACKEND=ollama
DEFAULT_MODEL_CLASS=light-latency
DEFAULT_DOMAIN_ID=academic_admin
DEFAULT_DOMAIN_NAME=Academic and administrative support
OLLAMA_MODEL=qwen3:4b
SHARED_OLLAMA_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://127.0.0.1:11434
VLLM_BASE_URL=http://127.0.0.1:8001
VLLM_API_KEY=EMPTY
OLLAMA_QWEN3_4B_MODEL=qwen3:4b
OLLAMA_QWEN3_8B_MODEL=qwen3:8b
OLLAMA_QWEN3_14B_MODEL=qwen3:14b
VLLM_QWEN3_4B_MODEL=Qwen/Qwen3-4B-AWQ
VLLM_QWEN3_8B_MODEL=Qwen/Qwen3-8B-AWQ
VLLM_QWEN3_14B_MODEL=Qwen/Qwen3-14B-AWQ
LLM_NUM_PREDICT=128
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
ENABLE_QUERY_REWRITE=conditional
ENABLE_VERIFICATION=conditional
ENABLE_STYLE_REWRITE=conditional
ENABLE_TOOL_SYNTHESIS=conditional
LOW_CONFIDENCE_THRESHOLD=0.45
REWRITE_MIN_WORDS=14
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_PORT=8501
STREAMLIT_API_BASE=http://127.0.0.1:8000
ENABLE_PERSONALIZATION=true
FIXED_ROUTE_MODE=adaptive
ALLOW_VLLM_ONLINE_JOINT_MODEL_SELECTION=false
